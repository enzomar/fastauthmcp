# yaml-language-server: $schema=ceramic.schema.json
# Ceramic Framework - Example Configuration
# Copy this file to ceramic.yaml and edit to match your setup.
# All sections are optional — omit any section to disable that feature.

# Authentication (OAuth2/OIDC)
auth:
  provider: oidc
  issuer: https://your-idp.example.com
  client_id: your-client-id
  # client_secret: ${CLIENT_SECRET}  # Use env var for secrets
  # grant_type: authorization_code   # authorization_code (browser login) or client_credentials (M2M) or token_exchange (headless/cloud)
  scopes:
    - openid
    - profile
    - email
  callback_timeout: 120    # Seconds to wait for browser callback (authorization_code only)
  token_exchange_timeout: 30

  # Token Exchange (RFC 8693) — for headless/cloud MCP deployments
  # When grant_type is token_exchange, Ceramic expects an upstream user token
  # in the request metadata and exchanges it for a downstream scoped token.
  # upstream_token_header: "x-user-token"     # Metadata key with the upstream token
  # token_exchange_audience: "https://api.internal.com"  # Target downstream API
  # token_exchange_scope: "read:orders write:orders"     # Scopes for downstream token

# Observability (traces, metrics, structured logging)
observability:
  enabled: true
  metrics_path: /metrics
  metrics_port: 9090
  exporter: otlp               # otlp | console | none
  otlp_endpoint: http://localhost:4317
  log_format: json             # json | text
  log_level: info              # debug | info | warning | error

# Session management
sessions:
  enabled: true
  ttl: 3600                    # Session TTL in seconds
  backend: memory              # memory (more backends coming)

# Plugins (third-party middleware)
# plugins:
#   - module: ceramic_rate_limit
#     config:
#       max_requests: 100
#       window_seconds: 60

# Hot reload (live config updates without restart)
hot_reload:
  enabled: true
  watch_interval: 5            # Seconds between file checks
  reloadable_sections:
    - observability
